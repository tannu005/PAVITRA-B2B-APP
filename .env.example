# -------------------------------------------------------------
# PAVITRA B2B - ENVIRONMENT CONFIGURATION
# -------------------------------------------------------------
# This is a sample file. Do NOT put real API keys in here!
# Copy this file to `.env` locally and input your real keys.

# 1. Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pavitra_b2b
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# 2. Payment Gateway (Razorpay/Stripe for B2B Checkout)
PAYMENT_GATEWAY_KEY="your_test_key_here"
PAYMENT_GATEWAY_SECRET="your_test_secret_here"

# 3. Cloud Storage (AWS S3 - for Seller Product Images)
AWS_ACCESS_KEY_ID="your_aws_key_here"
AWS_SECRET_ACCESS_KEY="your_aws_secret_here"
AWS_REGION="ap-south-1"
AWS_BUCKET_NAME="pavitra-b2b-storage"

# 4. Email Service (SendGrid - for Order Invoices & Alerts)
SENDGRID_API_KEY="your_sendgrid_key_here"
MAIL_FROM_ADDRESS="noreply@pavitrab2b.com"

# 5. SMS Service (Twilio/MSG91 - for Login OTPs)
SMS_API_KEY="your_sms_provider_key_here"
SMS_SENDER_ID="PAVITR"
